// Prisma Schema for "Is Durga Prasai In Jail Today?"
// MySQL database for chat, voting, and audio features

generator client {
  provider      = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum VoteType {
  KEEP
  RELEASE
}

model UserVote {
  id        String   @id @default(cuid())
  ipHash    String   @unique
  voteType  VoteType
  createdAt DateTime @default(now())

  @@index([ipHash])
}

model ChatMessage {
  id        String   @id @default(cuid())
  message   String   @db.VarChar(300)
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model AudioStat {
  id        Int @id @default(1)
  playCount Int @default(0)
}
